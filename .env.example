# ── Prism FM API ──────────────────────────────────────────────────────────────
# Generate your token in Prism > Settings > Developer
# Required scopes: read-events, read-venues, read-run-of-show
PRISM_TOKEN=your-prism-api-token-here

# ── Flask ──────────────────────────────────────────────────────────────────────
FLASK_DEBUG=1
SECRET_KEY=change-this-to-a-random-secret
# Host to bind to. 0.0.0.0 listens on all interfaces (reachable over the network).
# Use 127.0.0.1 to restrict to localhost only.
FLASK_HOST=0.0.0.0

# ── Database ───────────────────────────────────────────────────────────────────
# Path to the SQLite database file.  The directory must exist.
DATABASE_PATH=instance/prism.db

# ── Node.js bridge ─────────────────────────────────────────────────────────────
# Path to the directory containing the Node.js bridge scripts.
# Default is ./node_scripts relative to the project root.
NODE_SCRIPTS_DIR=node_scripts

# Timeout in seconds for a single Node.js SDK call (default 300 = 5 min).
# Increase if you have very large datasets.
NODE_TIMEOUT=300

# ── App behaviour ──────────────────────────────────────────────────────────────
# How many days ahead to look when no explicit window is requested (default 30).
DEFAULT_LOOKAHEAD_DAYS=30
